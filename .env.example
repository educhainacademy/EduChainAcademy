# Ethereum / Sepolia
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=your_deployer_private_key_here

# Alchemy API (for token prices, NFT metadata, portfolio data)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Polygon Amoy (optional)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# WalletConnect (for webapp)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Contract addresses (populated after deployment)
NEXT_PUBLIC_EDU_TOKEN_ADDRESS=
NEXT_PUBLIC_GAME_ITEM_ADDRESS=
NEXT_PUBLIC_GAME_LOGIC_ADDRESS=
NEXT_PUBLIC_QUEST_MANAGER_ADDRESS=
NEXT_PUBLIC_STAKING_ADDRESS=
NEXT_PUBLIC_GOVERNANCE_ADDRESS=
NEXT_PUBLIC_EDU_PLATFORM_ADDRESS=
NEXT_PUBLIC_SIMPLE_PAYMASTER_ADDRESS=

# Quest signing
QUEST_VERIFIER_PRIVATE_KEY=

# Geo-fencing
IP_GEO_SERVICE_URL=http://ip-api.com/json
GEO_FENCING_ENABLED=true

# KYC Provider (for compliance)
KYC_PROVIDER_API_KEY=
KYC_PROVIDER_WEBHOOK_SECRET=

# Compliance
DAILY_REWARD_CAP=50000
